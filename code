int potPin = A0;
int ledPin = 13;
int threshold = 500;
void setup() {
  pinMode(ledPin, OUTPUT);
  Serial.begin(9600);
}
void loop() {
  int value = analogRead(potPin);
  Serial.println(value);
  if (value > threshold) {
    digitalWrite(ledPin, HIGH);   // turn ON
  }
  else {
    digitalWrite(ledPin, LOW);    // turn OFF
  }
}
